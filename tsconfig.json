{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"removeComments": true,
		"isolatedModules": true
	},
	"include": ["src", "types.d.ts"]
}
