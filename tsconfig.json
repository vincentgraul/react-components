{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"removeComments": true,
		"isolatedModules": true,
		"types": ["vite/client"]
	},
	"include": ["src"]
}
